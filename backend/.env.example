# ──────────────────────────────────────────────────────────────────────────────
# Reel Automation Dashboard — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git (it is in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Primary: Gemini (google-generativeai SDK)
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash

# Fallback 1: Groq (fast, free tier available)
GROQ_API_KEY=

# Fallback 2: OpenAI (optional — only used if both above fail)
OPENAI_API_KEY=

# ── Text-to-Speech ─────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Video Clips (Pexels) ───────────────────────────────────────────────────────
PEXELS_API_KEY=

# ── Cloud Storage (AWS S3) ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1

# ── Instagram Publishing ──────────────────────────────────────────────────────
IG_USER_ID=
IG_ACCESS_TOKEN=

# ── GitHub Actions (optional — for hybrid serverless batch) ──────────────────
GITHUB_PAT=
GITHUB_REPO=yourname/reel-automation-dashboard
GITHUB_BRANCH=main

# ── HuggingFace Hub (optional) ────────────────────────────────────────────────
# Setting HF_TOKEN eliminates the unauthenticated-request warning from
# faster-whisper's model download and gives higher rate limits.
# Get a free read-only token at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── CORS (optional) ────────────────────────────────────────────────────────────
# Comma-separated extra frontend origins to whitelist (in addition to localhost
# and the hardcoded Netlify URL). Example: https://myapp.netlify.app
CORS_ORIGIN=
